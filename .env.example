NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — Mapbox + Google for the address picker
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# Optional — Upstash Redis for rate limiting (Vercel marketplace integration)
# When unset, rate limiting becomes a no-op.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — Sentry error monitoring. When unset, Sentry is a no-op.
# SENTRY_DSN is server-side; NEXT_PUBLIC_SENTRY_DSN is client-side. Use the
# same value for both.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Required only if you want source-map upload during build:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
